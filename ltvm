# Exit codes
EXIT_OK = 0
EXIT_ERROR = 1
EXIT_NOT_FOUND = 2


# ------------------------------------------------------------------
# Output helpers
# ------------------------------------------------------------------

def _output(data, use_json):
    """Print data as JSON or as a human-readable string."""
    if use_json:
        print(json.dumps(data, indent=2))
    else:
        if isinstance(data, str):
            print(data)
        elif isinstance(data, dict):
            for k, v in data.items():
                print(f"  {k}: {v}")
        elif isinstance(data, list):
            for item in data:
                print(item)


def _error(msg, use_json, hint=None):
    """Print an error message and return EXIT_ERROR."""
    if use_json:
        err = {"error": msg}
        if hint:
            err["hint"] = hint
        print(json.dumps(err, indent=2), file=sys.stderr)
    else:
        print(f"error: {msg}", file=sys.stderr)
        if hint:
            print(f"hint: {hint}", file=sys.stderr)
    return EXIT_ERROR


def _not_found(msg, use_json, hint=None):
    """Print a not-found message and return EXIT_NOT_FOUND."""
    if use_json:
        err = {"error": msg}
        if hint:
            err["hint"] = hint
        print(json.dumps(err, indent=2), file=sys.stderr)
    else:
        print(f"error: {msg}", file=sys.stderr)
        if hint:
            print(f"hint: {hint}", file=sys.stderr)
    return EXIT_NOT_FOUND


def _load_target(name, use_json):
    """Load a TargetConfig, returning (config, None) or
    (None, exit_code) on failure."""
    try:
        return TargetConfig(name), None
    except ValueError as e:
        targets = list_targets()
        hint = (f"Available targets: {', '.join(targets)}"
                if targets else "No targets configured")
        code = _not_found(str(e), use_json, hint=hint)
        return None, code


# ------------------------------------------------------------------
# Container status helper
# ------------------------------------------------------------------

def _container_status(target_config):
    """Return status dict for the build container artifact."""
    meta_file = (target_config.container_output_dir() /
                 "meta.json")
    if not meta_file.exists():
        return {"built": False, "stale": True}

    meta = json.loads(meta_file.read_text())
    stale = target_config.is_stale("container")
    return {"built": True, "stale": stale, **meta}


# ------------------------------------------------------------------
# Subcommand: init
# ------------------------------------------------------------------

def cmd_init(args):
    """Build container + kernel + image for a target."""
    use_json = args.json
    tc, err = _load_target(args.target, use_json)
    if err is not None:
        return err

    if not args.lustre_tree:
        return _error(
            "--lustre-tree is required for kernel builds",
            use_json,
            hint="ltvm init <target> --lustre-tree /path/to/lustre-release")

    lustre_tree = Path(args.lustre_tree).resolve()
    if not lustre_tree.is_dir():
        return _error(
            f"Lustre tree not found: {lustre_tree}",
            use_json)

    results = {}

    # 1. Container
    if not use_json:
        print(f"==> Building container for {args.target}...")
    try:
        _do_build_container(tc)
        results["container"] = "ok"
    except Exception as e:
        return _error(f"Container build failed: {e}", use_json)

    # 2. Kernel
    if not use_json:
        print(f"==> Building kernel for {args.target}...")
    try:
        kmeta = build_kernel(tc, lustre_tree, force=args.force)
        results["kernel"] = kmeta
    except Exception as e:
        return _error(f"Kernel build failed: {e}", use_json)

    # 3. Image
    if not use_json:
        print(f"==> Building image for {args.target}...")
    try:
        build_image(tc, force=args.force)
        results["image"] = "ok"
    except Exception as e:
        return _error(f"Image build failed: {e}", use_json)

    _output(results, use_json)
    return EXIT_OK


# ------------------------------------------------------------------
# Subcommand: build-container
# ------------------------------------------------------------------

def _do_build_container(target_config):
    """Run podman build for the build container and write meta."""
    tag = f"ltvm-build-{target_config.name}"
    dockerfile = (target_config.target_dir /
                  "container.Dockerfile")
    if not dockerfile.exists():
        raise FileNotFoundError(
            f"No container.Dockerfile for target "
            f"{target_config.name}")

    from lib.config import TARGETS_DIR
    subprocess.run(
        ["podman", "build", "-t", tag,
         "-f", str(dockerfile),
         str(TARGETS_DIR)],
        check=True)

    target_config.write_meta("container", image_tag=tag)
    return tag


def cmd_build_container(args):
    use_json = args.json
    tc, err = _load_target(args.target, use_json)
    if err is not None:
        return err

    if not use_json:
        print(f"Building container for {args.target}...")

    try:
        tag = _do_build_container(tc)
    except Exception as e:
        return _error(f"Container build failed: {e}", use_json)

    result = {"target": args.target, "image_tag": tag}
    _output(result, use_json)
    return EXIT_OK


